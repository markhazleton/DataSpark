@model Sql2Csv.Web.Models.UnifiedDataViewViewModel
@{
    ViewData["Title"] = $"Data View - {Model.DisplayName}";
    var fileTypeDisplay = Model.FileType == Sql2Csv.Core.Models.DataSourceType.Database ? "Database Table" : "CSV File";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center justify-between">
            <div>
                <nav class="flex items-center space-x-2 text-sm text-secondary-600 mb-2">
                    <a asp-action="Index" asp-controller="Home" class="hover:text-primary-600">Home</a>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                            clip-rule="evenodd" />
                    </svg>
                    <a asp-action="Analyze" asp-route-fileId="@Model.FileId" 
                       asp-route-fileType="@Model.FileType" asp-route-dataSourceName="@Model.DataSourceName"
                       class="hover:text-primary-600">@Model.DisplayName Analysis</a>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                            clip-rule="evenodd" />
                    </svg>
                    <span class="text-secondary-900">Data View</span>
                </nav>
                
                <div class="flex items-center mb-2">
                    <div class="bg-primary-100 rounded-lg p-2 mr-3">
                        @if (Model.FileType == Sql2Csv.Core.Models.DataSourceType.Database)
                        {
                            <svg class="w-6 h-6 text-primary-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 1.79 4 4 4h8c0 2.21 1.79 4 4 4V7c0-2.21-1.79-4-4-4H8c-2.21 0-4 1.79-4 4z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16" />
                            </svg>
                        }
                        else
                        {
                            <svg class="w-6 h-6 text-primary-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                        }
                    </div>
                    <div>
                        <h1 class="text-3xl font-bold text-secondary-900">@fileTypeDisplay Data: @Model.DisplayName</h1>
                        <p class="text-secondary-600 mt-1">Real-time data view with search, filtering, and pagination</p>
                    </div>
                </div>
            </div>
            
            <div class="flex space-x-3">
                <a asp-action="Analyze" asp-route-fileId="@Model.FileId" 
                   asp-route-fileType="@Model.FileType" asp-route-dataSourceName="@Model.DataSourceName"
                   class="btn-secondary">
                    <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                    </svg>
                    Back to Analysis
                </a>
                
                <button onclick="exportData()" class="btn-outline">
                    <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Export Data
                </button>
                
                <button onclick="refreshData()" class="btn-outline">
                    <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                    Refresh
                </button>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="card">
        <div class="card-header">
            <div class="flex items-center justify-between">
                <h2 class="text-xl font-bold text-secondary-900">Data Preview</h2>
                <div class="flex items-center space-x-4">
                    <div class="text-sm text-secondary-600">
                        <span id="recordsInfo">Loading...</span>
                    </div>
                    <div class="flex space-x-2">
                        <button onclick="toggleColumnVisibility()" class="btn-sm btn-outline">
                            <svg class="w-4 h-4 mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
                            </svg>
                            Columns
                        </button>
                    </div>
                </div>
            </div>
        </div>
        <div class="card-body p-0">
            <div class="overflow-hidden">
                <table id="dataTable" class="min-w-full divide-y divide-secondary-200">
                    <thead class="bg-secondary-50">
                        <!-- Table headers will be populated by DataTables -->
                    </thead>
                    <tbody class="bg-white divide-y divide-secondary-200">
                        <!-- Table body will be populated by DataTables -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Column Visibility Modal -->
    <div id="columnModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 overflow-y-auto h-full w-full hidden">
        <div class="relative top-20 mx-auto p-5 border w-96 shadow-lg rounded-md bg-white">
            <div class="mt-3">
                <h3 class="text-lg font-medium text-gray-900 mb-4">Column Visibility</h3>
                <div id="columnCheckboxes" class="space-y-2 max-h-60 overflow-y-auto">
                    <!-- Column checkboxes will be populated by JavaScript -->
                </div>
                <div class="flex justify-end mt-4 space-x-2">
                    <button onclick="hideColumnModal()" class="btn-secondary">Cancel</button>
                    <button onclick="applyColumnVisibility()" class="btn-primary">Apply</button>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let dataTable;
    const dataSourceConfig = {
        fileId: '@Model.FileId',
        fileType: '@Model.FileType',
        dataSourceName: '@Model.DataSourceName'
    };

    $(document).ready(function() {
        initializeDataTable();
    });

    function initializeDataTable() {
        dataTable = $('#dataTable').DataTable({
            processing: true,
            serverSide: true,
            ajax: {
                url: '@Url.Action("GetDataTableData")',
                type: 'POST',
                contentType: 'application/json',
                data: function(d) {
                    return JSON.stringify({
                        fileId: dataSourceConfig.fileId,
                        fileType: dataSourceConfig.fileType,
                        dataSourceName: dataSourceConfig.dataSourceName,
                        draw: d.draw,
                        start: d.start,
                        length: d.length,
                        search: d.search,
                        columns: d.columns,
                        order: d.order
                    });
                },
                error: function(xhr, error, thrown) {
                    console.error('DataTables error:', error, thrown);
                    alert('Error loading data. Please try again.');
                }
            },
            columns: [
                // Columns will be dynamically determined by the server response
            ],
            pageLength: 25,
            lengthMenu: [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
            responsive: true,
            scrollX: true,
            dom: '<"flex items-center justify-between mb-4"lf>rtip',
            language: {
                search: "Search:",
                lengthMenu: "Show _MENU_ entries",
                info: "Showing _START_ to _END_ of _TOTAL_ entries",
                infoEmpty: "Showing 0 to 0 of 0 entries",
                infoFiltered: "(filtered from _MAX_ total entries)",
                paginate: {
                    first: "First",
                    last: "Last",
                    next: "Next",
                    previous: "Previous"
                }
            },
            drawCallback: function(settings) {
                updateRecordsInfo(settings);
                setupColumnVisibility();
            }
        });
    }

    function updateRecordsInfo(settings) {
        const api = this.api();
        const info = api.page.info();
        $('#recordsInfo').text(`Showing ${info.start + 1} to ${info.end} of ${info.recordsTotal} entries`);
    }

    function setupColumnVisibility() {
        const columns = dataTable.columns().header().toArray();
        const checkboxContainer = $('#columnCheckboxes');
        checkboxContainer.empty();

        columns.forEach((header, index) => {
            const columnName = $(header).text();
            const isVisible = dataTable.column(index).visible();
            
            checkboxContainer.append(`
                <label class="flex items-center">
                    <input type="checkbox" ${isVisible ? 'checked' : ''} data-column="${index}" class="form-checkbox mr-2">
                    <span>${columnName}</span>
                </label>
            `);
        });
    }

    function toggleColumnVisibility() {
        $('#columnModal').removeClass('hidden');
    }

    function hideColumnModal() {
        $('#columnModal').addClass('hidden');
    }

    function applyColumnVisibility() {
        $('#columnCheckboxes input[type="checkbox"]').each(function() {
            const columnIndex = $(this).data('column');
            const isVisible = $(this).is(':checked');
            dataTable.column(columnIndex).visible(isVisible);
        });
        hideColumnModal();
    }

    function exportData() {
        // Export current view data to CSV
        const searchValue = dataTable.search();
        const orderColumn = dataTable.order()[0] ? dataTable.order()[0][0] : 0;
        const orderDirection = dataTable.order()[0] ? dataTable.order()[0][1] : 'asc';
        
        const exportForm = document.createElement('form');
        exportForm.method = 'POST';
        exportForm.action = '@Url.Action("Export")';
        exportForm.style.display = 'none';
        
        const fields = {
            fileId: dataSourceConfig.fileId,
            fileType: dataSourceConfig.fileType,
            selectedDataSources: [dataSourceConfig.dataSourceName],
            searchValue: searchValue,
            orderColumn: orderColumn,
            orderDirection: orderDirection
        };
        
        Object.keys(fields).forEach(key => {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = key;
            input.value = Array.isArray(fields[key]) ? fields[key].join(',') : fields[key];
            exportForm.appendChild(input);
        });
        
        document.body.appendChild(exportForm);
        exportForm.submit();
        document.body.removeChild(exportForm);
    }

    function refreshData() {
        dataTable.ajax.reload();
    }

    // Handle responsive design
    $(window).resize(function() {
        dataTable.columns.adjust().responsive.recalc();
    });
</script>

<style>
    /* Custom DataTables styling */
    .dataTables_wrapper .dataTables_length select,
    .dataTables_wrapper .dataTables_filter input {
        border: 1px solid #d1d5db;
        border-radius: 0.375rem;
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
    }
    
    .dataTables_wrapper .dataTables_filter input {
        margin-left: 0.5rem;
    }
    
    .dataTables_wrapper .dataTables_paginate .paginate_button {
        padding: 0.5rem 0.75rem;
        font-size: 0.875rem;
        border: 1px solid #d1d5db;
        background-color: white;
        color: #374151;
    }
    
    .dataTables_wrapper .dataTables_paginate .paginate_button:hover {
        background-color: #f9fafb;
    }
    
    .dataTables_wrapper .dataTables_paginate .paginate_button.current {
        background-color: #2563eb;
        color: white;
        border-color: #2563eb;
    }
    
    .dataTables_wrapper .dataTables_paginate .paginate_button.disabled {
        color: #9ca3af;
        cursor: not-allowed;
    }
    
    .dataTables_wrapper .dataTables_info {
        font-size: 0.875rem;
        color: #6b7280;
    }
    
    #dataTable th {
        background-color: #f9fafb;
        padding: 0.75rem 1.5rem;
        text-align: left;
        font-size: 0.75rem;
        font-weight: 500;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    
    #dataTable td {
        padding: 1rem 1.5rem;
        white-space: nowrap;
        font-size: 0.875rem;
        color: #111827;
    }
    
    #dataTable tbody tr:hover {
        background-color: #f9fafb;
    }
</style>
