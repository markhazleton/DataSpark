@model Sql2Csv.Web.Models.UnifiedDataSourceAnalysisViewModel
@{
    ViewData["Title"] = $"Analysis - {Model.DisplayName}";
    var fileTypeDisplay = "Database Table";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <script>
        window.dataSourceConfig = {
            fileId: '@Model.FileId',
            fileType: '@Model.FileType',
            dataSourceName: '@Model.DataSourceName',
            columns: @Json.Serialize(Model.Analysis.ColumnAnalyses.Select(c => new { name = c.ColumnName, type = c.DataType }))
        };
    </script>

    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center justify-between">
            <div>
                <nav class="flex items-center space-x-2 text-sm text-secondary-600 mb-2">
                    <a asp-action="Index" asp-controller="Home" class="hover:text-primary-600">Home</a>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                            clip-rule="evenodd" />
                    </svg>
                    <a asp-action="Index" asp-controller="Home" class="hover:text-primary-600">@Model.Analysis.FileName</a>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                            clip-rule="evenodd" />
                    </svg>
                    <span class="text-secondary-900">@Model.DisplayName Analysis</span>
                </nav>
                
                <div class="flex items-center mb-2">
                    <div class="bg-primary-100 rounded-lg p-2 mr-3">
                        <svg class="w-6 h-6 text-primary-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 1.79 4 4 4h8c0 2.21 1.79 4 4 4V7c0-2.21-1.79-4-4-4H8c-2.21 0-4 1.79-4 4z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7h16" />
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-3xl font-bold text-secondary-900">@fileTypeDisplay Analysis: @Model.DisplayName</h1>
                        <p class="text-secondary-600 mt-1">
                            <span class="font-medium">@Model.Analysis.FileName</span> •
                            @Model.Analysis.Summary.TotalColumns columns •
                            @Model.Analysis.Summary.TotalRows.ToString("N0") rows •
                            @Model.Analysis.Summary.FileSizeFormatted
                        </p>
                    </div>
                </div>
            </div>
            
            <div class="flex space-x-3">
                <a asp-action="Index" asp-controller="Home" class="btn-secondary">
                    <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                    Back to Home
                </a>
                
                @if (Model.CanViewData)
                {
                    <a asp-action="ViewData" asp-route-fileId="@Model.FileId" 
                       asp-route-fileType="@Model.FileType" asp-route-dataSourceName="@Model.DataSourceName" 
                       class="btn-primary">
                        <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>
                        View Data
                    </a>
                }
                
                <button onclick="exportAnalysis()" class="btn-outline">
                    <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Export Analysis
                </button>
            </div>
        </div>
    </div>

    @if (!Model.IsSuccess)
    {
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-8">
            <div class="flex">
                <svg class="w-5 h-5 text-red-400 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">Analysis Errors</h3>
                    @foreach (var error in Model.Errors)
                    {
                        <p class="text-sm text-red-700 mt-1">@error</p>
                    }
                </div>
            </div>
        </div>
    }

    @if (Model.IsSuccess)
    {
        <!-- Summary Statistics Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <!-- Total Rows -->
            <div class="card">
                <div class="card-header">
                    <div class="flex items-center">
                        <div class="bg-blue-100 rounded-lg p-2 mr-3">
                            <svg class="w-5 h-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold text-secondary-900">Total Rows</h3>
                            <p class="text-2xl font-bold text-blue-600">@Model.Analysis.Summary.TotalRows.ToString("N0")</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Total Columns -->
            <div class="card">
                <div class="card-header">
                    <div class="flex items-center">
                        <div class="bg-green-100 rounded-lg p-2 mr-3">
                            <svg class="w-5 h-5 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2h-2a2 2 0 00-2 2" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold text-secondary-900">Columns</h3>
                            <p class="text-2xl font-bold text-green-600">@Model.Analysis.Summary.TotalColumns</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- File Size -->
            <div class="card">
                <div class="card-header">
                    <div class="flex items-center">
                        <div class="bg-purple-100 rounded-lg p-2 mr-3">
                            <svg class="w-5 h-5 text-purple-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold text-secondary-900">File Size</h3>
                            <p class="text-2xl font-bold text-purple-600">@Model.Analysis.Summary.FileSizeFormatted</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Data Sources -->
            <div class="card">
                <div class="card-header">
                    <div class="flex items-center">
                        <div class="bg-orange-100 rounded-lg p-2 mr-3">
                            <svg class="w-5 h-5 text-orange-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                            </svg>
                        </div>
                        <div>
                            <h3 class="text-lg font-semibold text-secondary-900">Data Sources</h3>
                            <p class="text-2xl font-bold text-orange-600">@Model.Analysis.Summary.TotalDataSources</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Column Analysis Table -->
        <div class="card mb-8">
            <div class="card-header">
                <div class="flex items-center justify-between">
                    <h2 class="text-xl font-bold text-secondary-900">Column Analysis</h2>
                    <div class="flex space-x-2">
                        <button onclick="toggleColumnDetails()" class="btn-sm btn-outline">
                            <svg class="w-4 h-4 mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Toggle Details
                        </button>
                        <button onclick="exportColumnAnalysis()" class="btn-sm btn-primary">
                            <svg class="w-4 h-4 mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3" />
                            </svg>
                            Export
                        </button>
                    </div>
                </div>
            </div>
            <div class="card-body p-0">
                <div class="overflow-x-auto">
                    <table class="min-w-full divide-y divide-secondary-200">
                        <thead class="bg-secondary-50">
                            <tr>
                                <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Column</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Type</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Completeness</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Unique Values</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Statistics</th>
                                <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Sample Values</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-secondary-200">
                            @foreach (var column in Model.Analysis.ColumnAnalyses)
                            {
                                <tr class="hover:bg-secondary-50">
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <div class="flex-shrink-0 h-10 w-10">
                                                <div class="h-10 w-10 rounded-full bg-primary-100 flex items-center justify-center">
                                                    <span class="text-sm font-medium text-primary-600">@column.ColumnName[0]</span>
                                                </div>
                                            </div>
                                            <div class="ml-4">
                                                <div class="text-sm font-medium text-secondary-900">@column.ColumnName</div>
                                                @if (column.IsPrimaryKey)
                                                {
                                                    <div class="text-xs text-primary-600 font-medium">PRIMARY KEY</div>
                                                }
                                            </div>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-secondary-100 text-secondary-800">
                                            @column.DataType
                                        </span>
                                        @if (column.IsNullable)
                                        {
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800 ml-1">
                                                NULLABLE
                                            </span>
                                        }
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex items-center">
                                            <div class="w-16 bg-secondary-200 rounded-full h-2 mr-2">
                                                <div class="bg-green-600 h-2 rounded-full" style="width: @column.NonNullPercentage%"></div>
                                            </div>
                                            <span class="text-sm text-secondary-900">@column.NonNullPercentage.ToString("F1")%</span>
                                        </div>
                                        <div class="text-xs text-secondary-500">
                                            @column.NonNullCount.ToString("N0") / @column.TotalCount.ToString("N0")
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="text-sm text-secondary-900">@column.UniqueCount.ToString("N0")</div>
                                        <div class="text-xs text-secondary-500">@column.UniquePercentage.ToString("F1")% unique</div>
                                    </td>
                                    <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-900">
                                        @if (!string.IsNullOrEmpty(column.MinValue) && !string.IsNullOrEmpty(column.MaxValue))
                                        {
                                            <div>Range: @column.MinValue - @column.MaxValue</div>
                                        }
                                        @if (column.Mean.HasValue)
                                        {
                                            <div>Mean: @column.Mean.Value.ToString("F2")</div>
                                        }
                                        @if (column.StandardDeviation.HasValue)
                                        {
                                            <div>Std Dev: @column.StandardDeviation.Value.ToString("F2")</div>
                                        }
                                    </td>
                                    <td class="px-6 py-4 text-sm text-secondary-900">
                                        @if (column.SampleValues.Any())
                                        {
                                            <div class="space-y-1">
                                                @foreach (var sample in column.SampleValues.Take(3))
                                                {
                                                    <div class="bg-secondary-50 px-2 py-1 rounded text-xs">@sample</div>
                                                }
                                                @if (column.SampleValues.Count > 3)
                                                {
                                                    <div class="text-xs text-secondary-500">... and @(column.SampleValues.Count - 3) more</div>
                                                }
                                            </div>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        @if (Model.CanExport)
        {
            <!-- Export Options -->
            <div class="card">
                <div class="card-header">
                    <h2 class="text-xl font-bold text-secondary-900">Export Options</h2>
                </div>
                <div class="card-body">
                    <form asp-action="Export" method="post">
                        <input type="hidden" name="fileId" value="@Model.FileId" />
                        <input type="hidden" name="fileType" value="@Model.FileType" />
                        
                        <div class="space-y-4">
                            <div>
                                <label class="flex items-center">
                                    <input type="checkbox" name="selectedDataSources" value="@Model.DataSourceName" checked class="form-checkbox">
                                    <span class="ml-2">Export @Model.DisplayName</span>
                                </label>
                            </div>
                            
                            <div class="flex space-x-3">
                                <button type="submit" class="btn-primary">
                                    <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3" />
                                    </svg>
                                    Export to CSV
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        }
    }
</div>

<script>
    function exportAnalysis() {
        // Export functionality
        const analysisData = {
            dataSource: window.dataSourceConfig,
            columns: @Html.Raw(Json.Serialize(Model.Analysis.ColumnAnalyses)),
            summary: @Html.Raw(Json.Serialize(Model.Analysis.Summary))
        };
        
        const blob = new Blob([JSON.stringify(analysisData, null, 2)], { type: 'application/json' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${window.dataSourceConfig.dataSourceName}_analysis.json`;
        a.click();
        URL.revokeObjectURL(url);
    }
    
    function toggleColumnDetails() {
        // Toggle detailed column view
        console.log('Toggle column details');
    }
    
    function exportColumnAnalysis() {
        // Export column analysis to CSV
        const columns = @Html.Raw(Json.Serialize(Model.Analysis.ColumnAnalyses));
        const csv = 'Column,Type,Nullable,Total Count,Non-Null Count,Unique Count,Min Value,Max Value,Mean,Std Dev\n' +
            columns.map(c => `"${c.ColumnName}","${c.DataType}",${c.IsNullable},${c.TotalCount},${c.NonNullCount},${c.UniqueCount},"${c.MinValue || ''}","${c.MaxValue || ''}",${c.Mean || ''},${c.StandardDeviation || ''}`).join('\n');
        
        const blob = new Blob([csv], { type: 'text/csv' });
        const url = URL.createObjectURL(blob);
        const a = document.createElement('a');
        a.href = url;
        a.download = `${window.dataSourceConfig.dataSourceName}_column_analysis.csv`;
        a.click();
        URL.revokeObjectURL(url);
    }
</script>
