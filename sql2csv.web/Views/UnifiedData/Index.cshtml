@{
    ViewData["Title"] = "Unified Data Analysis";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header Section -->
    <div class="text-center mb-12">
        <h1 class="text-4xl font-bold text-secondary-900 mb-4">
            <span class="text-2xl mr-2">🔗</span>
            Unified Data Analysis
        </h1>
        <p class="text-xl text-secondary-600 max-w-3xl mx-auto">
            Analyze both database tables and CSV files using a single, unified interface. 
            Upload your data sources and explore them with consistent tools and visualizations.
        </p>
    </div>

    <!-- Feature Cards -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6 mb-12">
        <!-- Database Analysis -->
        <div class="bg-white rounded-lg shadow-sm border border-secondary-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center mb-4">
                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center mr-4">
                    <span class="text-2xl">🗄️</span>
                </div>
                <h3 class="text-lg font-semibold text-secondary-900">Database Tables</h3>
            </div>
            <p class="text-secondary-600 mb-4">
                Upload SQLite database files and analyze individual tables with comprehensive schema and data insights.
            </p>
            <ul class="text-sm text-secondary-500 space-y-1">
                <li>• Schema analysis and column statistics</li>
                <li>• Data type detection and validation</li>
                <li>• Primary key and constraint identification</li>
                <li>• Export to CSV with full control</li>
            </ul>
        </div>

        <!-- CSV Analysis -->
        <div class="bg-white rounded-lg shadow-sm border border-secondary-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center mb-4">
                <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center mr-4">
                    <span class="text-2xl">📊</span>
                </div>
                <h3 class="text-lg font-semibold text-secondary-900">CSV Files</h3>
            </div>
            <p class="text-secondary-600 mb-4">
                Upload and analyze CSV files with automatic data type inference and statistical analysis.
            </p>
            <ul class="text-sm text-secondary-500 space-y-1">
                <li>• Automatic header detection</li>
                <li>• Data type inference and validation</li>
                <li>• Statistical summaries and patterns</li>
                <li>• Data quality assessment</li>
            </ul>
        </div>

        <!-- Unified Features -->
        <div class="bg-white rounded-lg shadow-sm border border-secondary-200 p-6 hover:shadow-md transition-shadow">
            <div class="flex items-center mb-4">
                <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center mr-4">
                    <span class="text-2xl">🔗</span>
                </div>
                <h3 class="text-lg font-semibold text-secondary-900">Unified Interface</h3>
            </div>
            <p class="text-secondary-600 mb-4">
                Same analysis tools and visualizations regardless of your data source type.
            </p>
            <ul class="text-sm text-secondary-500 space-y-1">
                <li>• Consistent user experience</li>
                <li>• Interactive data viewing with pagination</li>
                <li>• Advanced filtering and search</li>
                <li>• Export and download capabilities</li>
            </ul>
        </div>
    </div>

    <!-- Getting Started Section -->
    <div class="bg-gradient-to-r from-primary-50 to-secondary-50 rounded-lg p-8 mb-8">
        <h2 class="text-2xl font-bold text-secondary-900 mb-4">Getting Started</h2>
        <div class="grid md:grid-cols-2 gap-6">
            <div>
                <h3 class="text-lg font-semibold text-secondary-800 mb-2">1. Upload Your Data</h3>
                <p class="text-secondary-600 mb-4">
                    Start by uploading your SQLite database or CSV file using the file upload interface.
                </p>
                <a asp-controller="Home" asp-action="Index" 
                   class="inline-flex items-center px-4 py-2 bg-primary-600 text-white rounded-md hover:bg-primary-700 transition-colors">
                    <span class="mr-2">📁</span>
                    Upload Files
                </a>
            </div>
            <div>
                <h3 class="text-lg font-semibold text-secondary-800 mb-2">2. Analyze and Explore</h3>
                <p class="text-secondary-600 mb-4">
                    Once uploaded, explore your data with our unified analysis tools and interactive viewers.
                </p>
                <a asp-controller="Home" asp-action="ManageFiles" 
                   class="inline-flex items-center px-4 py-2 bg-secondary-600 text-white rounded-md hover:bg-secondary-700 transition-colors">
                    <span class="mr-2">🔍</span>
                    Manage Files
                </a>
            </div>
        </div>
    </div>

    <!-- Key Benefits -->
    <div class="bg-white rounded-lg shadow-sm border border-secondary-200 p-8">
        <h2 class="text-2xl font-bold text-secondary-900 mb-6 text-center">Why Use Unified Analysis?</h2>
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
            <div class="text-center">
                <div class="w-16 h-16 bg-blue-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="text-2xl">⚡</span>
                </div>
                <h4 class="font-semibold text-secondary-900 mb-2">Fast Performance</h4>
                <p class="text-sm text-secondary-600">Optimized for quick analysis of large datasets</p>
            </div>
            <div class="text-center">
                <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="text-2xl">🎯</span>
                </div>
                <h4 class="font-semibold text-secondary-900 mb-2">Consistent Experience</h4>
                <p class="text-sm text-secondary-600">Same interface for all data source types</p>
            </div>
            <div class="text-center">
                <div class="w-16 h-16 bg-purple-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="text-2xl">📈</span>
                </div>
                <h4 class="font-semibold text-secondary-900 mb-2">Rich Analytics</h4>
                <p class="text-sm text-secondary-600">Comprehensive statistics and insights</p>
            </div>
            <div class="text-center">
                <div class="w-16 h-16 bg-orange-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <span class="text-2xl">💾</span>
                </div>
                <h4 class="font-semibold text-secondary-900 mb-2">Easy Export</h4>
                <p class="text-sm text-secondary-600">Export data in various formats</p>
            </div>
        </div>
    </div>
</div>
