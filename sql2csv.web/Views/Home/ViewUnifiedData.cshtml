@model Sql2Csv.Web.Models.UnifiedViewDataViewModel
@{
    ViewData["Title"] = $"View Data - {Model.DisplayName}";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-secondary-900">View Data</h1>
                <p class="text-secondary-600 mt-2">
                    <span class="font-medium">@Model.DisplayName</span> •
                    @Model.FileType.ToString() File •
                    @Model.Columns.Count columns
                    @if (Model.AdditionalInfo.ContainsKey("TotalRows"))
                    {
                        <span> • @Model.AdditionalInfo["TotalRows"] rows</span>
                    }
                    @if (Model.AdditionalInfo.ContainsKey("FileSize"))
                    {
                        <span> • @Model.AdditionalInfo["FileSize"]</span>
                    }
                </p>
            </div>
            <div class="flex space-x-3">
                <a href="javascript:history.back()" class="btn-secondary">
                    <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                    Back to Analysis
                </a>
                <a asp-action="Index" class="btn-primary">
                    <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                    </svg>
                    Upload New File
                </a>
            </div>
        </div>
    </div>

    <!-- Data Table -->
    <div class="bg-white rounded-xl shadow-sm border border-secondary-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-secondary-200">
            <h2 class="text-lg font-medium text-secondary-900">Data Preview</h2>
            <p class="text-sm text-secondary-600 mt-1">Interactive table with search, sort, and pagination</p>
        </div>
        
        <div class="p-6">
            <div class="overflow-x-auto">
                <table id="dataTable" class="min-w-full divide-y divide-secondary-200">
                    <thead class="bg-secondary-50">
                        <tr>
                            @foreach (var column in Model.Columns)
                            {
                                <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">
                                    <div class="flex flex-col">
                                        <span>@column.Name</span>
                                        <span class="text-xs font-normal text-secondary-400 capitalize">@column.DataType.ToLower()</span>
                                    </div>
                                </th>
                            }
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-secondary-200">
                        <!-- Data will be loaded via AJAX -->
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- Column Information -->
    <div class="mt-8 bg-white rounded-xl shadow-sm border border-secondary-200 p-6">
        <h3 class="text-lg font-medium text-secondary-900 mb-4">Column Information</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            @foreach (var column in Model.Columns)
            {
                <div class="p-4 border border-secondary-200 rounded-lg">
                    <h4 class="font-medium text-secondary-900">@column.Name</h4>
                    <div class="mt-2 space-y-1 text-sm text-secondary-600">
                        <div><span class="font-medium">Type:</span> @column.DataType</div>
                        <div><span class="font-medium">Nullable:</span> @(column.IsNullable ? "Yes" : "No")</div>
                        @if (column.IsPrimaryKey)
                        {
                            <div class="inline-flex items-center px-2 py-1 text-xs font-medium bg-blue-100 text-blue-800 rounded">
                                Primary Key
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var table = $('#dataTable').DataTable({
                processing: true,
                serverSide: true,
                ajax: {
                    url: '@Url.Action("GetUnifiedData")',
                    type: 'POST',
                    dataType: 'json',
                    error: function(xhr, error, thrown) {
                        console.error('DataTables error:', error, thrown);
                        alert('Error loading data: ' + (xhr.responseJSON?.error || error));
                    }
                },
                columns: [
                    @foreach (var column in Model.Columns)
                    {
                        <text>{ data: '@column.Name', name: '@column.Name', title: '@column.Name' },</text>
                    }
                ],
                pageLength: 25,
                lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
                scrollX: true,
                responsive: false,
                dom: '<"flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-4"<"flex items-center space-x-2"l><"flex items-center space-x-2"f>>rtip',
                language: {
                    search: '',
                    searchPlaceholder: 'Search data...',
                    lengthMenu: 'Show _MENU_ rows',
                    info: 'Showing _START_ to _END_ of _TOTAL_ rows',
                    infoEmpty: 'No data available',
                    infoFiltered: '(filtered from _MAX_ total rows)',
                    processing: '<div class="flex items-center justify-center py-4"><svg class="animate-spin -ml-1 mr-3 h-5 w-5 text-primary-600" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg>Loading data...</div>',
                    emptyTable: 'No data available in this file',
                    zeroRecords: 'No matching records found'
                },
                drawCallback: function(settings) {
                    // Apply Tailwind styles to DataTables elements
                    $('.dataTables_length select').addClass('form-select text-sm border-secondary-300 rounded-md shadow-sm');
                    $('.dataTables_filter input').addClass('form-input text-sm border-secondary-300 rounded-md shadow-sm');
                    $('.dataTables_paginate .paginate_button').addClass('px-3 py-2 text-sm font-medium text-secondary-500 bg-white border border-secondary-300 hover:bg-secondary-50 hover:text-secondary-700');
                    $('.dataTables_paginate .paginate_button.current').addClass('bg-primary-600 text-white border-primary-600 hover:bg-primary-700 hover:text-white');
                }
            });

            // Customize search input
            $('.dataTables_filter input').attr('placeholder', 'Search data...');
        });
    </script>
}
