@model Sql2Csv.Web.Models.CsvDetailedAnalysisViewModel
@{
    ViewData["Title"] = $"CSV Analysis - {Model.FileName}";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <script>
        window.tableColumns = @Json.Serialize(Model.ColumnAnalyses.Select(c => new { name = c.ColumnName, type = c.DataType }));
        window.fileName = '@Model.FileName';
        window.filePath = '@Model.FilePath';
    </script>
    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center justify-between">
            <div>
                <nav class="flex items-center space-x-2 text-sm text-secondary-600 mb-2">
                    <a asp-action="Index" class="hover:text-primary-600">Home</a>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                            clip-rule="evenodd" />
                    </svg>
                    <a asp-action="AnalyzeUnified" asp-route-fileName="@Model.FileName" class="hover:text-primary-600">@Model.FileName</a>
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd"
                            d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 111.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"
                            clip-rule="evenodd" />
                    </svg>
                    <span class="text-secondary-900">@Model.FileName Analysis</span>
                </nav>
                <h1 class="text-3xl font-bold text-secondary-900">CSV Analysis: @Model.FileName</h1>
                <p class="text-secondary-600 mt-2">
                    <span class="font-medium">@Model.FileType File</span> •
                    @Model.Summary.TotalColumns columns •
                    @Model.Summary.TotalRows.ToString("N0") rows •
                    Analysis completed in @Model.AnalysisDuration.TotalSeconds.ToString("F1")s
                </p>
            </div>
            <div class="flex space-x-3">
                <a asp-action="AnalyzeUnified" asp-route-fileName="@Model.FileName" class="btn-secondary">
                    <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                    Back to File
                </a>
                <a asp-action="ViewCsvData" asp-route-fileName="@Model.FileName" class="btn-primary">
                    <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    View Data
                </a>
                <button onclick="exportAnalysis()" class="btn-outline">
                    <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                        stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                    Export Analysis
                </button>
            </div>
        </div>
    </div>

    @{
        var columns = Model.IsSuccess ? Model.ColumnAnalyses.Select(c => new { name = c.ColumnName, type = c.DataType }) :
        Enumerable.Empty<dynamic>();
    }

    @if (!Model.IsSuccess)
    {
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 mb-8">
            <div class="flex">
                <svg class="w-5 h-5 text-red-400 mt-0.5" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
                <div class="ml-3">
                    <h3 class="text-sm font-medium text-red-800">Analysis Error</h3>
                    @foreach (var error in Model.Errors)
                    {
                        <p class="text-sm text-red-700 mt-1">@error</p>
                    }
                </div>
            </div>
        </div>
    }

    @if (Model.IsSuccess)
    {
        <!-- Summary Statistics Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
            <div class="card">
                <div class="card-header">
                    <div class="flex items-center">
                        <div class="bg-blue-100 rounded-lg p-2 mr-3">
                            <svg class="w-5 h-5 text-blue-600" xmlns="http://www.w3.org/2000/svg" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M4 7v10c0 2.21 1.79 4 4 4h8c0 2.21 1.79 4 4 4V7c0-2.21-1.79-4-4-4H8c-2.21 0-4 1.79-4 4z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-secondary-600">Total Rows</p>
                            <p class="text-2xl font-bold text-secondary-900">@Model.Summary.TotalRows.ToString("N0")</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="flex items-center">
                        <div class="bg-green-100 rounded-lg p-2 mr-3">
                            <svg class="w-5 h-5 text-green-600" xmlns="http://www.w3.org/2000/svg" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-secondary-600">Data Quality</p>
                            <p class="text-2xl font-bold text-secondary-900">@((Model.ColumnAnalyses.Average(c => c.NonNullPercentage)).ToString("F0"))%</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="flex items-center">
                        <div class="bg-purple-100 rounded-lg p-2 mr-3">
                            <svg class="w-5 h-5 text-purple-600" xmlns="http://www.w3.org/2000/svg" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-secondary-600">Column Types</p>
                            <p class="text-xs text-secondary-600">
                                @Model.ColumnAnalyses.Count(c => c.DataType.Contains("number") || c.DataType.Contains("decimal") || c.DataType.Contains("int")) Numeric •
                                @Model.ColumnAnalyses.Count(c => c.DataType.Contains("string") || c.DataType.Contains("text")) Text •
                                @Model.ColumnAnalyses.Count(c => c.DataType.Contains("date") || c.DataType.Contains("time")) Date
                            </p>
                            <p class="text-2xl font-bold text-secondary-900">@Model.Summary.TotalColumns</p>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="card-header">
                    <div class="flex items-center">
                        <div class="bg-orange-100 rounded-lg p-2 mr-3">
                            <svg class="w-5 h-5 text-orange-600" xmlns="http://www.w3.org/2000/svg" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-sm font-medium text-secondary-600">File Size</p>
                            <p class="text-2xl font-bold text-secondary-900">@Model.Summary.FileSizeFormatted</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Column Analysis Table -->
        <div class="card mb-8">
            <div class="card-header">
                <h2 class="text-xl font-semibold text-secondary-900">Column Analysis</h2>
                <p class="text-secondary-600 mt-1">Detailed statistics for each column</p>
            </div>

            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-secondary-200">
                    <thead class="bg-secondary-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">
                                Column</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">
                                Type</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">
                                Completeness</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">
                                Uniqueness</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">
                                Statistics</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">
                                Sample Values</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-secondary-200">
                        @foreach (var column in Model.ColumnAnalyses)
                        {
                            <tr class="hover:bg-secondary-50">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div>
                                            <div class="text-sm font-medium text-secondary-900">@column.ColumnName</div>
                                            <div class="text-xs text-secondary-500">
                                                @if (column.IsPrimaryKey)
                                                {
                                                    <span class="badge-primary">PK</span>
                                                }
                                                @if (!column.IsNullable)
                                                {
                                                    <span class="badge-secondary">NOT NULL</span>
                                                }
                                            </div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-sm font-mono text-secondary-900">@column.DataType</span>
                                    @if (column.DataType.Contains("number") || column.DataType.Contains("decimal") || column.DataType.Contains("int"))
                                    {
                                        <span class="badge-blue">Numeric</span>
                                    }
                                    else if (column.DataType.Contains("string") || column.DataType.Contains("text"))
                                    {
                                        <span class="badge-green">Text</span>
                                    }
                                    else if (column.DataType.Contains("date") || column.DataType.Contains("time"))
                                    {
                                        <span class="badge-purple">Date</span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-1">
                                            <div class="text-sm text-secondary-900">@column.NonNullPercentage.ToString("F1")%</div>
                                            <div class="w-full bg-secondary-200 rounded-full h-2 mt-1">
                                                <div class="bg-green-600 h-2 rounded-full"
                                                    style="width: @column.NonNullPercentage%"></div>
                                            </div>
                                            <div class="text-xs text-secondary-500 mt-1">@column.NonNullCount.ToString("N0") / @column.TotalCount.ToString("N0")</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-1">
                                            <div class="text-sm text-secondary-900">@column.UniquePercentage.ToString("F1")%</div>
                                            <div class="w-full bg-secondary-200 rounded-full h-2 mt-1">
                                                <div class="bg-blue-600 h-2 rounded-full"
                                                    style="width: @column.UniquePercentage%"></div>
                                            </div>
                                            <div class="text-xs text-secondary-500 mt-1">@column.UniqueCount.ToString("N0") unique</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-900">
                                    @if (!string.IsNullOrEmpty(column.MinValue) && !string.IsNullOrEmpty(column.MaxValue))
                                    {
                                        <div>Min: @column.MinValue</div>
                                        <div>Max: @column.MaxValue</div>
                                        @if (column.Mean.HasValue)
                                        {
                                            <div>Avg: @column.Mean.Value.ToString("F2")</div>
                                        }
                                        @if (column.StandardDeviation.HasValue)
                                        {
                                            <div>Std Dev: @column.StandardDeviation.Value.ToString("F2")</div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="text-secondary-500">N/A</span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-900">
                                    @if (column.SampleValues.Any())
                                    {
                                        <div class="max-w-xs">
                                            @foreach (var sample in column.SampleValues.Take(3))
                                            {
                                                <div class="text-xs bg-secondary-100 rounded px-2 py-1 mb-1 truncate">@sample</div>
                                            }
                                            @if (column.SampleValues.Count > 3)
                                            {
                                                <div class="text-xs text-secondary-500">+@(column.SampleValues.Count - 3) more</div>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-secondary-500">No samples</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- CSV Data Browser (if needed, could include a data viewer component here) -->
        <div class="card mb-8">
            <div class="card-header">
                <h2 class="text-xl font-semibold text-secondary-900">File Information</h2>
                <p class="text-secondary-600 mt-1">Details about the analyzed CSV file</p>
            </div>
            <div class="p-6">
                <dl class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        <dt class="text-sm font-medium text-secondary-500">File Name</dt>
                        <dd class="mt-1 text-sm text-secondary-900">@Model.FileName</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-secondary-500">File Type</dt>
                        <dd class="mt-1 text-sm text-secondary-900">@Model.FileType</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-secondary-500">Analysis Date</dt>
                        <dd class="mt-1 text-sm text-secondary-900">@Model.Summary.AnalysisDate.ToString("yyyy-MM-dd HH:mm:ss")</dd>
                    </div>
                    <div>
                        <dt class="text-sm font-medium text-secondary-500">Analysis Duration</dt>
                        <dd class="mt-1 text-sm text-secondary-900">@Model.AnalysisDuration.TotalSeconds.ToString("F2") seconds</dd>
                    </div>
                </dl>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function exportAnalysis() {
            function esc(val) { if (val === null || val === undefined) return '""'; const s = String(val).replace(/"/g,'""'); return '"'+s+'"'; }
            let csv = 'Column,Type,Total Count,Null Count,Non-Null Count,Unique Count,Completeness %,Uniqueness %,Min Value,Max Value,Mean,Std Deviation\n';
            @foreach (var column in Model.ColumnAnalyses)
            {
                <text>
                csv += esc('@column.ColumnName')+','+esc('@column.DataType')+','+@column.TotalCount+','+@column.NullCount+','+@column.NonNullCount+','+@column.UniqueCount+','+@column.NonNullPercentage.ToString("F2")+','+@column.UniquePercentage.ToString("F2")+','+esc('@(column.MinValue ?? "N/A")')+','+esc('@(column.MaxValue ?? "N/A")')+','+esc('@(column.Mean?.ToString("F2") ?? "N/A")')+','+esc('@(column.StandardDeviation?.ToString("F2") ?? "N/A")')+"\\n";
                </text>
            }
            const blob = new Blob([csv], { type: 'text/csv' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = '@Model.FileName-analysis.csv';
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);
        }

        function copyToClipboard(text) {
            navigator.clipboard.writeText(text).then(function () {
                // Show success message
                const toast = document.createElement('div');
                toast.className = 'fixed top-4 right-4 bg-green-500 text-white px-4 py-2 rounded-lg shadow-lg z-50';
                toast.textContent = 'Copied to clipboard!';
                document.body.appendChild(toast);
                setTimeout(() => {
                    document.body.removeChild(toast);
                }, 3000);
            });
        }
    </script>
}
