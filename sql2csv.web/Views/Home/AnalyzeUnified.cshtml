@{
    ViewData["Title"] = "Database Analysis";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-secondary-900">Database Analysis</h1>
                <p class="text-secondary-600 mt-2">
                    Processing database file...
                </p>
            </div>
            <a asp-action="Index" class="btn-secondary">
                <svg class="w-5 h-5 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                </svg>
                Back to Upload
            </a>
        </div>
        
        <!-- Database Redirect -->
        <div class="bg-white rounded-xl shadow-sm border border-secondary-200 p-6">
            <h2 class="text-xl font-semibold text-secondary-900 mb-4">Processing Database File</h2>
            <p class="text-secondary-600 mb-4">This is a database file. Redirecting to database analysis...</p>
            <div class="flex items-center justify-center py-8">
                <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-secondary-900"></div>
                <span class="ml-3 text-secondary-600">Loading...</span>
            </div>
            <script>
                setTimeout(function() {
                    window.location.href = '@Url.Action("Analyze")';
                }, 2000);
            </script>
        </div>
    </div>
</div>
