@model Sql2Csv.Web.Models.UnifiedAnalysisViewModel
@{
    ViewData["Title"] = "Data Analysis";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8">
        <div class="flex items-center justify-between">
            <div>
                <h1 class="text-3xl font-bold text-secondary-900">Data Analysis</h1>
                <p class="text-secondary-600 mt-2">
                    <span class="font-medium">@Model.FileName</span> •
                    @Model.FileType.ToString() File •
                    @Model.Summary.TotalDataSources data source(s) •
                    @Model.Summary.TotalColumns columns •
                    @Model.Summary.TotalRows.ToString("N0") rows •
                    @Model.Summary.FileSizeFormatted
                </p>
            </div>
            <a asp-action="Index" class="btn-secondary">
                <svg class="w-4 h-4 mr-2" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                </svg>
                Upload New File
            </a>
        </div>
    </div>

    @if (Model.Errors.Any())
    {
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
            <h3 class="text-red-800 font-medium mb-2">Analysis Warnings</h3>
            <ul class="text-red-700 text-sm space-y-1">
                @foreach (var error in Model.Errors)
                {
                    <li>• @error</li>
                }
            </ul>
        </div>
    }

    <!-- Data Sources -->
    <div class="mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-secondary-200 p-6">
            <h2 class="text-xl font-semibold text-secondary-900 mb-4">Available Data Sources</h2>
            
            @if (Model.FileType == Sql2Csv.Core.Models.DataSourceType.Csv)
            {
                <!-- CSV File Actions -->
                <div class="space-y-4">
                    @foreach (var dataSource in Model.DataSources)
                    {
                        <div class="p-4 border border-secondary-200 rounded-lg">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h3 class="font-medium text-secondary-900">@dataSource.DisplayName</h3>
                                    <p class="text-sm text-secondary-600">@dataSource.Description</p>
                                    @if (dataSource.AdditionalInfo.Any())
                                    {
                                        <div class="mt-2 text-xs text-secondary-500 space-x-4">
                                            @foreach (var info in dataSource.AdditionalInfo)
                                            {
                                                <span>@info.Key: @info.Value</span>
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="flex space-x-2">
                                    <a asp-action="ViewCsvData" asp-route-fileName="@Model.FileName" 
                                       class="btn-primary text-sm">
                                        <svg class="w-4 h-4 mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                        </svg>
                                        View Data
                                    </a>
                                    <a asp-action="AnalyzeCsvDetail" asp-route-fileName="@Model.FileName"
                                       class="btn-secondary text-sm">
                                        <svg class="w-4 h-4 mr-1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" />
                                        </svg>
                                        Detailed Analysis
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
            else
            {
                <!-- Database Tables (fallback to existing behavior) -->
                <p class="text-secondary-600 mb-4">This appears to be a database file. Redirecting to database analysis...</p>
                <script>
                    setTimeout(function() {
                        window.location.href = '@Url.Action("Analyze")';
                    }, 2000);
                </script>
            }
        </div>
    </div>

    @if (Model.FileType == Sql2Csv.Core.Models.DataSourceType.Csv && Model.ColumnAnalyses.Any())
    {
        <!-- Column Analysis Summary -->
        <div class="mb-8">
            <div class="bg-white rounded-xl shadow-sm border border-secondary-200 p-6">
                <h2 class="text-xl font-semibold text-secondary-900 mb-4">Column Analysis Summary</h2>
                
                <div class="grid gap-4">
                    <div class="overflow-x-auto">
                        <table class="min-w-full divide-y divide-secondary-200">
                            <thead class="bg-secondary-50">
                                <tr>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Column</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Type</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Non-Null</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Unique</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Range</th>
                                    <th class="px-6 py-3 text-left text-xs font-medium text-secondary-500 uppercase tracking-wider">Sample Values</th>
                                </tr>
                            </thead>
                            <tbody class="bg-white divide-y divide-secondary-200">
                                @foreach (var column in Model.ColumnAnalyses.Take(10))
                                {
                                    <tr>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <div class="text-sm font-medium text-secondary-900">@column.ColumnName</div>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap">
                                            <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium 
                                                @(column.DataType == "TEXT" ? "bg-blue-100 text-blue-800" : 
                                                  column.DataType == "INTEGER" ? "bg-green-100 text-green-800" :
                                                  column.DataType == "REAL" ? "bg-purple-100 text-purple-800" :
                                                  "bg-gray-100 text-gray-800")">
                                                @column.DataType
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500">
                                            @column.NonNullCount.ToString("N0") (@column.NonNullPercentage.ToString("F1")%)
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500">
                                            @column.UniqueCount.ToString("N0") (@column.UniquePercentage.ToString("F1")%)
                                        </td>
                                        <td class="px-6 py-4 whitespace-nowrap text-sm text-secondary-500">
                                            @if (!string.IsNullOrEmpty(column.MinValue) && !string.IsNullOrEmpty(column.MaxValue))
                                            {
                                                <span>@column.MinValue - @column.MaxValue</span>
                                            }
                                            else
                                            {
                                                <span class="text-secondary-400">N/A</span>
                                            }
                                        </td>
                                        <td class="px-6 py-4 text-sm text-secondary-500">
                                            <div class="max-w-xs truncate">
                                                @string.Join(", ", column.SampleValues.Take(3))
                                                @if (column.SampleValues.Count > 3)
                                                {
                                                    <span class="text-secondary-400">...</span>
                                                }
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                    
                    @if (Model.ColumnAnalyses.Count > 10)
                    {
                        <div class="text-center py-4">
                            <p class="text-secondary-600">Showing first 10 columns. 
                               <a asp-action="AnalyzeCsvDetail" asp-route-fileName="@Model.FileName" 
                                  class="text-primary-600 hover:underline">View detailed analysis</a> for all @Model.ColumnAnalyses.Count columns.
                            </p>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="bg-white rounded-xl shadow-sm border border-secondary-200 p-6">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <svg class="w-8 h-8 text-blue-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                </div>
                <div class="ml-4">
                    <div class="text-sm font-medium text-secondary-500">File Size</div>
                    <div class="text-2xl font-bold text-secondary-900">@Model.Summary.FileSizeFormatted</div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-secondary-200 p-6">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <svg class="w-8 h-8 text-green-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4" />
                    </svg>
                </div>
                <div class="ml-4">
                    <div class="text-sm font-medium text-secondary-500">Total Rows</div>
                    <div class="text-2xl font-bold text-secondary-900">@Model.Summary.TotalRows.ToString("N0")</div>
                </div>
            </div>
        </div>

        <div class="bg-white rounded-xl shadow-sm border border-secondary-200 p-6">
            <div class="flex items-center">
                <div class="flex-shrink-0">
                    <svg class="w-8 h-8 text-purple-500" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17V7m0 10a2 2 0 01-2 2H5a2 2 0 01-2-2V7a2 2 0 012-2h2a2 2 0 012 2m0 10a2 2 0 002 2h2a2 2 0 002-2M9 7a2 2 0 012-2h2a2 2 0 012 2m0 10V7m0 10a2 2 0 002 2h2a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2h2a2 2 0 002-2z" />
                    </svg>
                </div>
                <div class="ml-4">
                    <div class="text-sm font-medium text-secondary-500">Total Columns</div>
                    <div class="text-2xl font-bold text-secondary-900">@Model.Summary.TotalColumns</div>
                </div>
            </div>
        </div>
    </div>
</div>
