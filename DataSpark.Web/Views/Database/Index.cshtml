@model DataSpark.Web.Models.Database.DatabaseIndexViewModel
@{
    ViewData["Title"] = "Database Files";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="fas fa-database me-2"></i>SQLite Database Tools</h2>
</div>

@if (!string.IsNullOrWhiteSpace(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}
@if (!string.IsNullOrWhiteSpace(Model.SuccessMessage) || TempData["DatabaseSuccess"] != null)
{
    <div class="alert alert-success">@(Model.SuccessMessage ?? TempData["DatabaseSuccess"])</div>
}

<div class="card mb-4">
    <div class="card-header">Upload Database</div>
    <div class="card-body">
        <form asp-action="Upload" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">SQLite File</label>
                    <input class="form-control" type="file" name="file" accept=".db,.sqlite,.sqlite3" required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Description (optional)</label>
                    <input class="form-control" type="text" name="description" maxlength="200" />
                </div>
                <div class="col-md-2 d-flex align-items-end">
                    <button class="btn btn-primary w-100" type="submit">Upload</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">Managed Files</div>
    <div class="card-body p-0">
        @if (Model.Files.Count == 0)
        {
            <div class="p-3 text-muted">No uploaded databases yet.</div>
        }
        else
        {
            <table class="table table-striped table-hover mb-0">
                <thead>
                    <tr>
                        <th>File</th>
                        <th>Size</th>
                        <th>Tables</th>
                        <th>Uploaded</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var file in Model.Files)
                    {
                        <tr>
                            <td>@file.OriginalFileName</td>
                            <td>@file.FormattedFileSize</td>
                            <td>@file.TableCount</td>
                            <td>@file.FormattedUploadDate</td>
                            <td class="text-end">
                                <a class="btn btn-sm btn-outline-primary" asp-action="Analyze" asp-route-fileId="@file.Id">Analyze</a>
                                <form asp-action="Delete" method="post" class="d-inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="fileId" value="@file.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
